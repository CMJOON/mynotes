rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && getUser().role == "admin";
    }
    function hasFileUrl(data) {
      return data.keys().hasAny(["fileUrl"]);
    }
    // 判断 material 是否公开可访问（无需付费）
    function isFreeContent(data) {
      return data.type == "trial"
          || data.type == "pastyear"
          || data.isFree == true;
    }
    function hasSubjectAccess(data) {
      return data.accessKey is string
          && getUser().paidSubjects is list
          && getUser().paidSubjects.hasAny([data.accessKey]);
    }
    function canAccessPaidContent(data) {
      return isSignedIn()
          && (
            isAdmin()
            || (
              getUser().role == "paid"
              && (
                getUser().paidPackage == "premium"
                || (data.formPackage is string && getUser().paidPackage == data.formPackage)
                || hasSubjectAccess(data)
              )
            )
          );
    }
    function isSafeMaterialData(data) {
      return !hasFileUrl(data);
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.role == "free"
        && request.resource.data.paidPackage == null
        && request.resource.data.paidSubjects is list
        && request.resource.data.paidSubjects.size() == 0;

      // 本人只能改非权限字段
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(["role", "paidPackage", "paidSubjects"]);

      // Admin 可以改权限，但不能操作其他 admin，也不能晋升任何人为 admin
      allow update: if isAdmin()
        && resource.data.role != "admin"
        && request.resource.data.role != "admin";

      match /savedMaterials/{materialId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId)
          && isSafeMaterialData(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /recentMaterials/{materialId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId)
          && isSafeMaterialData(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /completedMaterials/{materialId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId)
          && isSafeMaterialData(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    // ── materials ──────────────────────────────────────────────────────────
    match /materials/{materialId} {
      // materials 只保存公开可展示的 metadata；PDF 链接必须放在 materialFiles。
      allow read: if true;

      allow create, update: if isAdmin()
        && isSafeMaterialData(request.resource.data);
      allow delete: if isAdmin();
    }

    // ── protected material files ───────────────────────────────────────────
    match /materialFiles/{materialId} {
      allow read: if isAdmin()
        || isFreeContent(resource.data)
        || canAccessPaidContent(resource.data);
      allow write: if isAdmin();
    }

    // ── subjects ───────────────────────────────────────────────────────────
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── 兜底拒绝 ───────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
